{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist/cjs",

    "module": "commonjs",
    "target": "ES2019",
    "moduleResolution": "node",

    "declaration": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "verbatimModuleSyntax": false
  },
  "include": ["src/**/*.ts"]
}
