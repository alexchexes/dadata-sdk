    "SuggestMetroPayload": {
      "type": "object",
      "properties": {
        "query": {
          "type": "string",
          "description": "Query string\n@maxLength 300",
          "maxLength": 300
        },
        "count": {
          "type": "number",
          "description": "Maximum number of results to fetch\n@minimum 1\n@maximum 20\n@default 10",
          "minimum": 1,
          "maximum": 20,
          "default": 10
        },
        "filters": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/SuggestMetroFilter"
          },
          "description": "Фильтрация станций метро по различным параметрам.\n\nПримеры:\n- Поиск среди станций Санкт-Петербурга:\n  `[{ city_kladr_id: \"7800000000000\" }]`\n\n- Поиск среди открытых станций Кольцевой ветки Москвы:\n  `[{ city: \"Москва\", line_id: \"5\", is_closed: null }]`\n\n* Поля внутри одного фильтра интерпретируются как `AND`, между фильтрами - как `OR`"
        }
      },
      "additionalProperties": false,
      "required": [
        "query"
      ],
      "description": "@see https://dadata.ru/api/suggest/metro/"
    },
