      "type": "object",
      "properties": {
        "city_kladr_id": {
          "type": "string",
          "description": "КЛАДР-код города (например, \"7700000000000\" для Москвы)"
        },
        "city_fias_id": {
          "type": "string",
          "description": "ФИАС-код города (например, \"0c5b2444-70a0-4932-980c-b4dc0d3f02b5\" для Москвы)"
        },
        "city": {
          "type": "string",
          "description": "Название города (например, \"Москва\")"
        },
        "line_id": {
          "type": "string",
          "description": "Номер линии метро (например, \"5\" для Кольцевой линии)"
        },
        "is_closed": {
          "type": [
            "boolean",
            "null"
          ],
          "enum": [
            true,
            null
          ],
          "description": "Фильтр по признаку «закрыта»\n- `true` - только закрытые\n- `null` - только открытые\n@note Документация на https://dadata.ru/api/suggest/metro/ предполагает здесь `true/false`,\nоднако фактически API использует `true/null`."
        }
      },
      "additionalProperties": false
    },
