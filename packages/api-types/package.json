{
  "name": "@dadata-sdk/api-types",
  "version": "0.1.0",
  "description": "TypeScript request and response contracts for the DaData API.",
  "keywords": [
    "dadata",
    "typescript",
    "types",
    "api",
    "openapi",
    "json-schema"
  ],
  "homepage": "https://alexchexes.github.io/dadata-sdk/en/spec",
  "bugs": {
    "url": "https://github.com/alexchexes/dadata-sdk/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/alexchexes/dadata-sdk",
    "directory": "packages/api-types"
  },
  "license": "MIT",
  "author": "Alex Chexes <alexchexes@gmail.com>",
  "type": "commonjs",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "require": "./dist/cjs/index.js",
      "import": "./dist/esm/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "prepare": "pnpm build",
    "clean": "rimraf dist",
    "build": "pnpm run clean && pnpm run build:types && pnpm run build:esm && pnpm run build:cjs && pnpm run prune:stubs && pnpm run gen:schema && pnpm run gen:spec",
    "build:types": "tsc -p tsconfig.types.json && node -e \"require('fs').copyFileSync('src/index.d.ts','dist/index.d.ts')\"",
    "build:esm": "tsc -p tsconfig.esm.json",
    "build:cjs": "tsc -p tsconfig.cjs.json",
    "prune:stubs": "rimraf dist/cjs/types dist/esm/types",
    "gen:schema": "pnpm exec schema-gen --input schema-types --output ../api-spec/schemas",
    "gen:spec": "pnpm redocly bundle ../api-spec/dadata.yaml -o ../api-spec/dadata.json"
  },
  "devDependencies": {
    "@types/node": "^22.15.29",
    "chalk": "^5.4.1",
    "rimraf": "^6.0.1",
    "tsx": "^4.19.4",
    "@dadata-sdk/schema-gen": "workspace:*"
  },
  "publishConfig": {
    "access": "public"
  }
}
