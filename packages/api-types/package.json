{
  "name": "@dadata-sdk/api-types",
  "version": "0.1.0",
  "description": "Typed contract + JSON Schema for every Dadata endpoint",
  "type": "commonjs",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "json-schema"
  ],
  "exports": {
    ".": {
      "require": "./dist/cjs/index.js",
      "import": "./dist/esm/index.js",
      "types": "./dist/index.d.ts"
    },
    "./schema/*": "./json-schema/*"
  },
  "scripts": {
    "clean": "rimraf dist",
    "build": "pnpm run clean && pnpm run build:types && pnpm run build:esm && pnpm run build:cjs && pnpm run prune:stubs && pnpm run gen:schema",
    "build:types": "tsc -p tsconfig.types.json && node -e \"require('fs').copyFileSync('src/index.d.ts','dist/index.d.ts')\"",
    "build:esm": "tsc -p tsconfig.esm.json",
    "build:cjs": "tsc -p tsconfig.cjs.json",
    "prune:stubs": "rimraf dist/cjs/types dist/esm/types",
    "gen:schema": "tsx schema-gen/main.ts"
  },
  "dependencies": {
    "type-fest": "^4.41.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.29",
    "chalk": "^5.4.1",
    "rimraf": "^6.0.1",
    "ts-json-schema-generator": "2.4.1-next.0",
    "tsx": "^4.19.4"
  }
}
