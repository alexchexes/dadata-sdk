{
  "name": "@dadata-sdk/api-types",
  "version": "0.1.0",
  "description": "Typed contract + JSON Schema for every Dadata endpoint",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "schemas"
  ],
  "exports": {
    ".": {
      "default": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./schema/*": "./schemas/*"
  },
  "scripts": {
    "build": "pnpm build-only && pnpm run gen:schema",
    "build-only": "tsc -p tsconfig.build.json",
    "gen:schema": "tsx schema-gen/main.ts"
  },
  "dependencies": {
    "type-fest": "^4.39.1"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "chalk": "^5.4.1",
    "ts-json-schema-generator": "2.4.1-next.0",
    "tsx": "^4.19.3"
  }
}
