{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "baseUrl": ".",
    "rootDir": ".",
    "composite": false,
    "emitDeclarationOnly": false,
    "paths": {
      "@/*": ["src/*"]
    },
    "skipLibCheck": true,
    "types": ["node"]
  },
  "include": ["src/**/*.ts", "schema-gen/**/*"]
}
