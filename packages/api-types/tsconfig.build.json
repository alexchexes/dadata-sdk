{
  "extends": "./tsconfig.json",
  "include": ["src/**/*"],
  "exclude": ["src/**/__tests__/*", "src/**/*.test.ts"],
  "compilerOptions": {
    "baseUrl": ".",
    "composite": true,
    "declaration": true,
    "outDir": "dist",
    "rootDir": "src",
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "module": "es6",
    "moduleResolution": "node",
    "target": "ES2019",
    "paths": {
      "@/*": ["src/*"]
    }
  }
}
