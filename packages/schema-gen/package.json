{
  "name": "@dadata-sdk/schema-gen",
  "version": "0.1.0",
  "description": "Generate JSON Schema from TypeScript types",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "schema-gen": "./dist/cli.js"
  },
  "exports": {
    ".": "./dist/index.js"
  },
  "scripts": {
    "prepare": "pnpm build",
    "build": "tsc -p tsconfig.json",
    "cli": "tsx src/cli.js",
    "schema-gen": "pnpm cli"
  },
  "dependencies": {
    "chalk": "^5.4.1",
    "commander": "^11.1.0",
    "prettier": "^3.5.3",
    "ts-json-schema-generator": "2.5.0-next.5"
  },
  "devDependencies": {
    "@types/node": "^22.15.29",
    "tsx": "^4.19.4"
  },
  "engines": {
    "node": ">=22"
  }
}
