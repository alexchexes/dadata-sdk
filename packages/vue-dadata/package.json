{
  "name": "@dadata-sdk/vue",
  "version": "0.1.0",
  "description": "Unofficial Vue 3.5+ component for the DaData suggestions API.",
  "keywords": [
    "dadata",
    "suggestions",
    "autocomplete",
    "address",
    "vue",
    "vue3",
    "typescript",
    "postal address"
  ],
  "homepage": "https://alexchexes.github.io/dadata-sdk/en/vue",
  "bugs": {
    "url": "https://github.com/alexchexes/dadata-sdk/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/alexchexes/dadata-sdk",
    "directory": "packages/vue-dadata"
  },
  "license": "MIT",
  "author": "Alex Chexes <alexchexes@gmail.com>",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/types/vue-dadata.es.d.ts",
      "import": "./dist/vue-dadata.js",
      "require": "./dist/vue-dadata.cjs"
    },
    "./*": "./*"
  },
  "main": "./dist/vue-dadata.cjs",
  "module": "./dist/vue-dadata.js",
  "types": "./dist/types/vue-dadata.es.d.ts",
  "files": [
    "dist",
    "src/**/*.vue",
    "README.md"
  ],
  "scripts": {
    "prepare": "pnpm build",
    "analyze": "vite build --config analyze.config.js",
    "build": "run-p type-check \"build-only {@}\" --",
    "build-only": "vite build",
    "coverage": "vitest run --coverage",
    "coverage:report": "vite preview --outDir ./coverage",
    "dev": "vite --host",
    "dev:docs": "vitepress dev docs --port=8081",
    "format": "prettier --write src/",
    "lint": "eslint . --fix",
    "preview": "vite preview",
    "sort": "npx sort-package-json",
    "test": "vitest",
    "type-check": "vue-tsc --build"
  },
  "dependencies": {
    "@dadata-sdk/api-types": "workspace:*",
    "@vueuse/core": "^13.3.0",
    "axios": "^1.9.0"
  },
  "devDependencies": {
    "@types/jsdom": "^21.1.7",
    "@vitejs/plugin-vue": "^5.2.4",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.7.0",
    "jsdom": "^26.1.0",
    "npm-run-all2": "^8.0.4",
    "rollup-plugin-visualizer": "^6.0.1",
    "vite": "^6.3.5",
    "vite-plugin-dts": "^4.5.4",
    "vite-plugin-vue-devtools": "^7.7.6",
    "vue-tsc": "^3.3.1"
  },
  "peerDependencies": {
    "vue": "^3.5.18"
  },
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public"
  }
}
