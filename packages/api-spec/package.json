{
  "name": "@dadata-sdk/api-spec",
  "version": "0.1.0",
  "private": false,
  "description": "Bundled OpenAPI and JSON Schema artifacts for the DaData API.",
  "keywords": [
    "dadata",
    "openapi",
    "json-schema",
    "schema",
    "api"
  ],
  "homepage": "https://alexchexes.github.io/dadata-sdk/en/spec",
  "bugs": {
    "url": "https://github.com/alexchexes/dadata-sdk/issues"
  },
  "author": "Alex Chexes <alexchexes@gmail.com>",
  "license": "MIT",
  "files": [
    "dadata.json",
    "schemas/request.json",
    "schemas/response.json",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/alexchexes/dadata-sdk",
    "directory": "packages/api-spec"
  },
  "scripts": {
    "build": "pnpm run gen:artifacts",
    "type-check": "tsc -p tsconfig.scripts.json --noEmit",
    "gen:schemas": "pnpm exec schema-gen --input ../api-types/schema-types --output ./schemas",
    "gen:bundle": "pnpm exec tsx ./scripts/bundle-openapi.ts ./dadata.yaml ./dadata.json",
    "gen:artifacts": "pnpm run gen:schemas && pnpm run gen:bundle",
    "check:official-upstream": "pnpm exec tsx ./scripts/check-official-upstream.ts",
    "compare:official": "pnpm exec tsx ./scripts/compare-official.ts",
    "compare:official:suggestions-stage-a": "pnpm exec tsx ./scripts/compare-official-suggestions-stage-a.ts",
    "compare:official:suggestions-stage-b": "pnpm exec tsx ./scripts/compare-official-suggestions-stage-b.ts",
    "compare:official:suggestions-stage-b:check-snapshot": "pnpm exec tsx ./scripts/compare-official-suggestions-stage-b.ts --check-snapshot",
    "compare:official:suggestions-stage-b:update-snapshot": "pnpm exec tsx ./scripts/compare-official-suggestions-stage-b.ts --update-snapshot"
  },
  "devDependencies": {
    "@dadata-sdk/schema-gen": "workspace:*",
    "@redocly/cli": "^2.0.2",
    "@scalar/openapi-types": "^0.3.7",
    "@types/node": "^24.1.0",
    "prettier": "^3.6.2",
    "tsx": "^4.19.4",
    "yaml": "^2.8.3"
  },
  "publishConfig": {
    "access": "public"
  }
}
