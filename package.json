{
  "name": "dadata-sdk",
  "private": true,
  "packageManager": "pnpm@10.11.1",
  "version": "0.0.0",
  "workspaces": [
    "packages/*",
    "docs"
  ],
  "scripts": {
    "build": "pnpm -r build && pnpm docs:gen-vue-schema && pnpm docs:build",
    "test": "pnpm -r test",
    "lint": "eslint \"**/*.{ts,tsx,vue}\"",
    "dev": "pnpm docs:dev",
    "docs:dev": "rm -rf docs/.vitepress/cache && pnpm vitepress dev docs --host",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "docs:gen-vue-schema": "pnpm -F schema-gen schema-gen --input ../../docs/vue-component.types.ts --output ../../docs/vue-component-schema.json",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "publish-packages": "changeset publish",
    "release": "pnpm run version-packages && pnpm -r build && pnpm run publish-packages"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.5",
    "@redocly/cli": "^1.34.4",
    "@scalar/openapi-types": "^0.3.5",
    "@shikijs/langs": "^3.7.0",
    "@shikijs/themes": "^3.7.0",
    "@tailwindcss/postcss": "^4.1.11",
    "@trivago/prettier-plugin-sort-imports": "^5.2.2",
    "@tsconfig/node22": "^22.0.2",
    "@types/json-schema": "^7.0.15",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^22.15.32",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/eslint-plugin": "1.2.1",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.5.1",
    "@vueuse/core": "^13.4.0",
    "eslint": "^9.29.0",
    "eslint-plugin-vue": "^10.2.0",
    "markdown-it": "^14.1.0",
    "postcss": "^8.5.6",
    "prettier": "^3.5.3",
    "prettier-plugin-organize-attributes": "^1.0.0",
    "prettier-plugin-tailwindcss": "^0.6.13",
    "shiki": "^3.7.0",
    "tailwind-merge": "^3.3.1",
    "tailwindcss": "^4.1.11",
    "typescript": "~5.8.3",
    "vitepress": "^1.6.3",
    "vitest": "^3.2.4",
    "vue": "^3.5.17"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "scule": "^1.3.0",
    "vitepress-openapi": "link:../vitepress-openapi",
    "vue-i18n": "^11.1.7"
  }
}
