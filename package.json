{
  "name": "dadata-sdk",
  "private": true,
  "packageManager": "pnpm@10.11.1",
  "version": "0.0.0",
  "workspaces": [
    "packages/*",
    "docs"
  ],
  "scripts": {
    "build": "pnpm -r build && pnpm docs:gen-vue-schema && pnpm docs:build",
    "test": "pnpm -r test",
    "lint": "eslint \"**/*.{ts,tsx,vue}\"",
    "dev": "pnpm docs:dev",
    "docs:dev": "rm -rf docs/.vitepress/cache && pnpm vitepress dev docs --host",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "docs:gen-vue-schema": "pnpm -F schema-gen schema-gen --input ../../docs/component.types.ts --output ../../docs/component-schema.json",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "publish-packages": "changeset publish",
    "release": "pnpm run version-packages && pnpm -r build && pnpm run publish-packages"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.4",
    "@shikijs/langs": "^3.6.0",
    "@shikijs/themes": "^3.6.0",
    "@tailwindcss/postcss": "^4.1.8",
    "@tsconfig/node22": "^22.0.2",
    "@types/node": "^22.15.30",
    "@vitest/coverage-v8": "^3.2.2",
    "@vitest/eslint-plugin": "1.2.1",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.5.0",
    "@vueuse/core": "^13.3.0",
    "eslint": "^9.28.0",
    "eslint-plugin-vue": "^10.2.0",
    "postcss": "^8.5.4",
    "prettier": "^3.5.3",
    "prettier-plugin-organize-attributes": "^1.0.0",
    "prettier-plugin-tailwindcss": "^0.6.12",
    "shiki": "^3.6.0",
    "tailwind-merge": "^3.3.0",
    "tailwindcss": "^4.1.8",
    "typescript": "~5.8.3",
    "vitepress": "^1.6.3",
    "vitest": "^3.2.2",
    "vue": "^3.5.16"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "vue-i18n": "^11.1.5"
  }
}
