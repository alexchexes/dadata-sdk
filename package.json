{
  "name": "dadata-sdk",
  "private": true,
  "packageManager": "pnpm@10.17.1",
  "version": "0.0.0",
  "workspaces": [
    "packages/*",
    "docs"
  ],
  "scripts": {
    "build": "pnpm -r build && pnpm docs:gen-vue-schema && pnpm docs:build",
    "type-check": "pnpm run type-check:scripts && pnpm -r --if-present type-check",
    "type-check:scripts": "tsc -p tsconfig.scripts.json --noEmit",
    "test": "pnpm -r test",
    "lint": "eslint \"**/*.{ts,tsx,vue}\"",
    "gen:api-artifacts": "pnpm --filter @dadata-sdk/api-spec gen:artifacts",
    "check:official-upstream": "pnpm --filter @dadata-sdk/api-spec check:official-upstream",
    "compare:official": "pnpm --filter @dadata-sdk/api-spec compare:official",
    "compare:official:suggestions-stage-a": "pnpm --filter @dadata-sdk/api-spec compare:official:suggestions-stage-a",
    "verify:generated": "pnpm exec tsx ./scripts/verify-generated.ts",
    "dev": "pnpm docs:dev",
    "docs:dev": "rm -rf docs/.vitepress/cache && pnpm vitepress dev docs --host",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "docs:gen-vue-schema": "pnpm -F schema-gen schema-gen --input ../../docs/vue-component.types.ts --output ../../docs/vue-component-schema.json",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "publish-packages": "changeset publish",
    "release": "pnpm run version-packages && pnpm -r build && pnpm run publish-packages"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.5",
    "@redocly/cli": "^2.0.2",
    "@scalar/openapi-types": "^0.3.7",
    "@shikijs/langs": "^3.8.1",
    "@shikijs/themes": "^3.8.1",
    "@tailwindcss/postcss": "^4.1.11",
    "@trivago/prettier-plugin-sort-imports": "^5.2.2",
    "@tsconfig/node22": "^22.0.2",
    "@types/json-schema": "^7.0.15",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^24.1.0",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/eslint-plugin": "1.3.4",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.6.0",
    "@vueuse/core": "^13.6.0",
    "eslint": "^9.32.0",
    "eslint-plugin-vue": "^10.3.0",
    "markdown-it": "^14.1.0",
    "postcss": "^8.5.6",
    "prettier": "^3.6.2",
    "prettier-plugin-organize-attributes": "^1.0.0",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "shiki": "^3.8.1",
    "tailwind-merge": "^3.3.1",
    "tailwindcss": "^4.1.11",
    "tsx": "^4.19.4",
    "typescript": "~5.8.3",
    "vite": "^5.4.19",
    "vite-plugin-vue-devtools": "^7.7.6",
    "vitepress": "^1.6.3",
    "vitest": "^3.2.4",
    "vue": "^3.5.18",
    "vue-tsc": "^2.2.10",
    "yaml": "^2.8.3"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "scule": "^1.3.0",
    "vitepress-openapi": "^0.1.19",
    "vue-i18n": "^11.1.11"
  }
}
