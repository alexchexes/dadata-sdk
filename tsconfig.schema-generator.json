{
  "extends": "./tsconfig.app.json",
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "baseUrl": ".",
    "composite": false,
    "emitDeclarationOnly": false,
    "paths": {
      "@/*": ["src/*"]
    },
    "skipLibCheck": true,
    "types": ["node"]
  },
  "include": ["src/types/**/*.ts", "src/const/**/*.ts", "json-schema-generator/**/*"]
}
